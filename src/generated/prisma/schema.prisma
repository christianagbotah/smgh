generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Event {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  date            DateTime
  time            String?
  venue           String
  city            String
  address         String?
  description     String?  @db.Text
  bannerImage     String?
  status          String   @default("upcoming")
  tags            String?  @db.Text
  youtubeUrls     String?  @db.Text
  attendanceCount Int      @default(0)
  ticketPrice     Float?
  ticketCurrency  String   @default("GHS")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  artists      EventArtist[]
  guests       EventGuest[]
  testimonials EventTestimonial[]
  galleryItems GalleryItem[]
  rsvps        EventRSVP[]
  products     Product[]
}

model EventArtist {
  id        String @id @default(cuid())
  eventId   String
  artistId  String
  event     Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  artist    Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  sortOrder Int    @default(0)

  @@unique([eventId, artistId])
}

model EventGuest {
  id          String  @id @default(cuid())
  eventId     String
  name        String
  title       String?
  photo       String?
  description String?
  sortOrder   Int     @default(0)
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventTestimonial {
  id      String  @id @default(cuid())
  eventId String
  quote   String  @db.Text
  author  String
  photo   String?
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model GalleryItem {
  id                 String            @id @default(cuid())
  title              String?
  description        String?
  type               String            @default("image")
  url                String
  thumbnail          String?
  eventId            String?
  event              Event?            @relation(fields: [eventId], references: [id], onDelete: SetNull)
  foundationRecordId String?
  foundationRecord   FoundationRecord? @relation(fields: [foundationRecordId], references: [id], onDelete: SetNull)
  year               Int?
  category           String?
  sortOrder          Int               @default(0)
  createdAt          DateTime          @default(now())
}

model Artist {
  id        String        @id @default(cuid())
  name      String
  location  String?
  bio       String?       @db.Text
  image     String?
  featured  Boolean       @default(false)
  events    EventArtist[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Donation {
  id                String   @id @default(cuid())
  name              String
  email             String?
  phone             String?
  address           String?
  amount            Float
  currency          String   @default("GHS")
  paymentMethod     String   @default("manual")
  paymentProvider   String?
  status            String   @default("pending")
  reference         String?
  message           String?  @db.Text
  donorType         String   @default("individual")
  donationFrequency String?
  organization      String?
  createdAt         DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("editor")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaFile {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  photo       String?
  bio         String?  @db.Text
  email       String?
  phone       String?
  socialLinks String?  @db.Text
  category    String   @default("leadership")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FoundationRecord {
  id                 String        @id @default(cuid())
  year               Int
  description        String        @db.Text
  amountRaised       Float?
  amountSpent        Float?
  beneficiariesCount Int?
  locations          String?       @db.Text
  galleryItems       GalleryItem[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model EventRSVP {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  email     String?
  phone     String?
  guests    Int      @default(1)
  message   String?  @db.Text
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  basePrice    Float
  currency     String   @default("GHS")
  category     String   @default("tshirt")
  eventId      String?
  event        Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  primaryImage String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  variants   ProductVariant[]
  orderItems OrderItem[]
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  name       String
  color      String
  colorName  String
  size       String
  price      Float
  stock      Int         @default(0)
  image      String?
  isActive   Boolean     @default(true)
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([productId, colorName, size])
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  customerName    String
  customerEmail   String?
  customerPhone   String
  deliveryAddress String?
  deliveryCity    String?
  deliveryRegion  String?
  status          String   @default("pending")
  paymentProvider String?
  paymentStatus   String   @default("pending")
  paymentRef      String?
  totalAmount     Float
  currency        String   @default("GHS")
  trackingNumber  String?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items OrderItem[]
}

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  productId        String?
  productVariantId String?
  productName      String
  variantName      String?
  quantity         Int
  unitPrice        Float
  totalPrice       Float
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
}

model CustomPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String   @default("") @db.Text
  bannerImage String?
  status      String   @default("draft")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Beneficiary {
  id         String   @id @default(cuid())
  name       String
  story      String?  @db.Text
  photo      String?
  category   String?
  location   String?
  yearHelped Int?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}
