generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./db/smgh.db"
}

model Event {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  date           DateTime
  time           String?
  venue          String
  city           String
  address        String?
  description    String?
  bannerImage    String?
  status         String   @default("upcoming")
  tags           String?
  youtubeUrls    String?
  attendanceCount Int     @default(0)
  ticketPrice    Float?
  ticketCurrency String   @default("GHS")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  artists       EventArtist[]
  guests        EventGuest[]
  testimonials  EventTestimonial[]
  galleryItems  GalleryItem[]
  rsvps         EventRSVP[]
  products      Product[]
}

model EventArtist {
  id        String  @id @default(cuid())
  eventId   String
  artistId  String
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  artist    Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  sortOrder Int     @default(0)
  @@unique([eventId, artistId])
}

model EventGuest {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  title       String?
  photo       String?
  description String?
  sortOrder   Int      @default(0)
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventTestimonial {
  id      String @id @default(cuid())
  eventId String
  quote   String
  author  String
  photo   String?
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model GalleryItem {
  id                  String @id @default(cuid())
  title               String?
  description         String?
  type                String @default("image")
  url                 String
  thumbnail           String?
  eventId             String?
  event               Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  foundationRecordId  String?
  foundationRecord    FoundationRecord? @relation(fields: [foundationRecordId], references: [id], onDelete: SetNull)
  year                Int?
  category            String?
  sortOrder           Int     @default(0)
  createdAt           DateTime @default(now())
}

model Artist {
  id        String       @id @default(cuid())
  name      String
  location  String?
  bio       String?
  image     String?
  featured  Boolean      @default(false)
  events    EventArtist[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Donation {
  id               String   @id @default(cuid())
  name             String
  email            String?
  phone            String?
  address          String?
  amount           Float
  currency         String   @default("GHS")
  paymentMethod    String   @default("manual")
  paymentProvider  String?  // "paystack", "hubtel", or null for manual
  status           String   @default("pending")
  reference        String?
  message          String?
  donorType        String   @default("individual")
  donationFrequency String?
  organization     String?
  createdAt        DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("editor") // "super_admin" or "editor"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaFile {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  photo       String?
  bio         String?
  email       String?
  phone       String?
  socialLinks String?
  category    String   @default("leadership")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FoundationRecord {
  id                String        @id @default(cuid())
  year              Int
  description       String
  amountRaised      Float?
  amountSpent       Float?
  beneficiariesCount Int?
  locations         String?
  galleryItems      GalleryItem[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model EventRSVP {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  email     String?
  phone     String?
  guests    Int      @default(1)
  message   String?
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  basePrice     Float
  currency      String   @default("GHS")
  category      String   @default("tshirt")
  eventId       String?
  event         Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  primaryImage  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  variants    ProductVariant[]
  orderItems  OrderItem[]
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String  // e.g. "Black / Large"
  color     String  // e.g. "#000000"
  colorName String  // e.g. "Black"
  size      String  // e.g. "L"
  price     Float   // override price if different from base
  stock     Int     @default(0)
  image     String? // variant-specific mockup image
  isActive  Boolean @default(true)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@unique([productId, colorName, size])
}

model Order {
  id             String   @id @default(cuid())
  orderNumber    String   @unique
  customerName   String
  customerEmail  String?
  customerPhone  String
  deliveryAddress String?
  deliveryCity    String?
  deliveryRegion String?
  status         String   @default("pending") // pending, confirmed, processing, shipped, delivered, cancelled
  paymentProvider String?  // "paystack", "hubtel", or null
  paymentStatus  String   @default("pending") // pending, paid, failed
  paymentRef     String?
  totalAmount    Float
  currency       String   @default("GHS")
  trackingNumber String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items OrderItem[]
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String?
  productVariantId String?
  productName     String
  variantName     String?
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  productVariant  ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
}

model CustomPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @default("") // HTML content from rich text editor
  bannerImage String?
  status    String   @default("draft") // "draft" or "published"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Beneficiary {
  id          String   @id @default(cuid())
  name        String
  story       String?
  photo       String?
  category    String?
  location    String?
  yearHelped  Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}
